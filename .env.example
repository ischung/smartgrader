# ============================
# Frontend 환경변수 (frontend/.env)
# ============================
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key
VITE_API_URL=https://your-render-app.onrender.com

# ============================
# Backend 환경변수 (backend/.env)
# ============================
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
SUPABASE_ANON_KEY=your-anon-key

# CORS 허용 도메인 (콤마 구분)
ALLOWED_ORIGINS=http://localhost:3000,https://your-vercel-app.vercel.app

# ============================
# GitHub Secrets (CI/CD 전용 — 로컬에서는 사용 안 함)
# ============================
# DB 마이그레이션 자동 배포용 연결 문자열
# 획득 경로: Supabase 대시보드 → Settings → Database → Connection string → URI → Session mode (포트 5432)
# 등록 경로: GitHub → Repository → Settings → Secrets and variables → Actions → SUPABASE_DB_URL
# SUPABASE_DB_URL=postgres://postgres.[project-ref]:[password]@aws-0-ap-northeast-1.pooler.supabase.com:5432/postgres

# ============================
# 관리자 계정 초기화 (최초 1회 수동 — 이후 자동)
# ============================
# 마이그레이션 적용 후 Supabase 대시보드에서:
#   Authentication → Users → "Create new user"
#   Email: admin@smartgrader.local / Password: 원하는 값
#   → 트리거가 즉시 public.users에 login_id=110509, role=admin 으로 자동 등록
